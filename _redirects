# Mathrone Academy — Cloudflare Pages redirects

# News articles: serve the SPA (JS handles the article fetch)
/news/:slug  /index.html  200

# Shop products: serve the SPA
/shop/:id    /index.html  200

# Auth token flows: serve the SPA
/verify/:token   /index.html  200
