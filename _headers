/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self "https://meet.jit.si"), microphone=(self "https://meet.jit.si"), display-capture=(self "https://meet.jit.si"), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://meet.jit.si https://www.youtube.com https://www.youtube-nocookie.com https://s.ytimg.com https://fonts.googleapis.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com https://fonts.bunny.net https://www.youtube.com; font-src 'self' data: https://fonts.gstatic.com https://fonts.bunny.net https://cdn.jsdelivr.net; img-src 'self' data: https: blob: https://i.ytimg.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://mathrone-backend.onrender.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://api.anthropic.com https://fonts.bunny.net; frame-src 'self' https://meet.jit.si https://www.youtube.com https://youtube.com https://www.youtube-nocookie.com https://phet.colorado.edu; frame-ancestors 'self';
  # Brotli/gzip compression hint for Cloudflare
  Vary: Accept-Encoding

# SPA shell — always revalidate so new deploys are picked up immediately
/index.html
  Cache-Control: public, no-cache, must-revalidate
  Vary: Accept-Encoding
  X-Content-Type-Options: nosniff

/
  Cache-Control: public, no-cache, must-revalidate
  Vary: Accept-Encoding

# App JS and CSS — versioned by deploy, cache 1 year
/app.js
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

/style.css
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

# Component scripts
/components/*.js
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

# Service Worker — never cache, must always be fresh
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept-Encoding

# Images at root
/og-banner.jpg
  Cache-Control: public, max-age=2592000
  Vary: Accept-Encoding
/favicon.png
  Cache-Control: public, max-age=2592000

# Manifest
/manifest.json
  Cache-Control: public, max-age=86400

# Sitemap and robots
/sitemap.xml
  Cache-Control: public, max-age=3600
  Vary: Accept-Encoding

/robots.txt
  Cache-Control: public, max-age=86400